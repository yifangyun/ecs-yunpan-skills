# 360 AI云盘 Skill 环境配置
# 复制此文件为 .env 并填写实际值

# ========================================
# 连接模式（二选一）
# ========================================
# npx   : 远程 npm 包（需要 Node.js 环境）
# http  : HTTP API（推荐，最简单）
MCP_MODE=http

# ========================================
# 鉴权配置（所有模式必填）
# ========================================
API_KEY=your_api_key_here
ECS_ENV=prod
SUB_CHANNEL=open

# ========================================
# 各模式专用配置
# ========================================
# HTTP 模式: 配置 API 端点
MCP_HTTP_URL=https://mcp.yunpan.com/mcp
# MCP_HTTP_TIMEOUT=30

# 上传工具自动降级（HTTP -> npx）
# npx: 自动降级（默认）  off: 禁用自动降级
MCP_UPLOAD_FALLBACK=npx
