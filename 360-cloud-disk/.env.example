# 360 云盘 Skill 环境配置
# 复制此文件为 .env 并填写实际值

# ========================================
# 连接模式（三选一）
# ========================================
# local : 本地开发（需要 MCP_SERVER_DIR）
# npx   : 远程 npm 包（需要 Node.js 环境）
# http  : HTTP API（推荐，最简单）
MCP_MODE=http

# ========================================
# 鉴权配置（所有模式必填）
# ========================================
# 静态配置：适用于单用户场景
API_KEY=your_api_key_here
ECS_ENV=prod
SUB_CHANNEL=open

# ========================================
# 动态鉴权（多用户场景）
# ========================================
# 动态鉴权优先级高于静态配置，适用于多用户服务器部署
# 每次调用前设置环境变量即可，无需修改此文件
#
# 示例：
#   MCP_API_KEY=user1_key python3 executor.py user-info
#   MCP_API_KEY=user2_key python3 executor.py file-list path=/
#
# 支持的动态环境变量：
#   MCP_API_KEY      - 动态 API 密钥（覆盖 API_KEY）
#   MCP_ECS_ENV      - 动态环境配置（覆盖 ECS_ENV）
#   MCP_SUB_CHANNEL  - 动态渠道配置（覆盖 SUB_CHANNEL）

# ========================================
# 各模式专用配置
# ========================================
# HTTP 模式: 配置 API 端点
MCP_HTTP_URL=https://mcp.yunpan.com/mcp
# MCP_HTTP_TIMEOUT=30

# Local 模式: 配置 MCP Server 源码目录
# MCP_SERVER_DIR=/path/to/ecs_mcp
